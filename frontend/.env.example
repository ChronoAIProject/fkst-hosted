# ==============================================================================
# FKST Console - Frontend Environment Variables Template (.env.example)
# ==============================================================================
#
# Copy this file to '.env' in the frontend directory to configure the Vite app.
#
# SECURITY WARNING: Never place actual secrets (API keys, passwords, private keys)
# in this file or any .env file that gets loaded into the Vite production bundle.
# Vite environment variables prefixed with VITE_ are embedded into the client-side
# bundle as plain-text and are publicly visible to anyone inspecting the frontend.
#

# ------------------------------------------------------------------------------
# 1. FKST Hosted Backend API Base URL
# ------------------------------------------------------------------------------
# The HTTP API endpoint of the fkst-hosted backend.
# If left empty or unset, the client defaults to same-origin requests (e.g., "").
#
# Local Dev Example:
VITE_FKST_API_BASE=http://127.0.0.1:8080
# Deployed Example:
# VITE_FKST_API_BASE=https://api.hosted.chronoai.co

# ------------------------------------------------------------------------------
# 2. NyxID IAM Integration
# ------------------------------------------------------------------------------

# The base URL of the NyxID authentication server.
# Used for OAuth authorization code flow, login redirects, and JWKS fetching.
VITE_NYXID_BASE_URL=https://nyx.chrono-ai.fun

# The client ID registered with NyxID for this frontend application.
VITE_NYXID_CLIENT_ID=fkst-hosted-frontend

# The OAuth redirect URI registered for the login flow.
# Must match a registered redirect URI in NyxID's client registration.
VITE_NYXID_REDIRECT_URI=http://localhost:5173/auth/callback

# The direct connection URL to connect a GitHub account through the NyxID credential proxy.
VITE_NYXID_CONNECT_GITHUB_URL=https://nyx.chrono-ai.fun/api/v1/github/connect

# ------------------------------------------------------------------------------
# 3. Security Settings
# ------------------------------------------------------------------------------

# Master toggle for requiring authentication on the frontend.
# - true: Default full-auth posture. Users must log in via NyxID.
# - false: DEV/observer posture. All routes open, auth prompts bypassed.
VITE_AUTH_REQUIRED=true
