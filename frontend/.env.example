# ==============================================================================
# FKST Console - Frontend Environment Variables Template
# ==============================================================================
#
# SECURITY WARNING: Never place actual secrets (API keys, passwords, private keys)
# in this file or any .env file that gets loaded into the Vite production bundle.
# Vite environment variables prefixed with VITE_ are embedded into the client-side
# bundle as plain-text and are publicly visible to anyone inspecting the frontend.
#

# ------------------------------------------------------------------------------
# FKST Hosted Backend API Base URL
# ------------------------------------------------------------------------------
# Default: If left empty or unset, the client defaults to same-origin requests (e.g. "").
#
# Local Dev Example (pointing to the local Rust backend port 8080):
VITE_FKST_API_BASE=http://127.0.0.1:8080
#
# Deployed Hosted Backend Example (placeholder line):
# VITE_FKST_API_BASE=https://api.hosted.chronoai.co

# ------------------------------------------------------------------------------
# NyxID Base URL
# ------------------------------------------------------------------------------
# Default: If left empty or unset, the client defaults to same-origin requests (e.g. "").
# Reserved for future IAM (Identity & Access Management) integration under NyxID.
#
# Local Dev Example:
# VITE_NYXID_BASE_URL=http://127.0.0.1:8081
#
# Deployed Hosted IAM Example (placeholder line):
# VITE_NYXID_BASE_URL=https://iam.chronoai.co

# ------------------------------------------------------------------------------
# NyxID Auth Configuration
# ------------------------------------------------------------------------------
# Enable or disable required OAuth authentication.
# Default: false (observer mode); set true to require login.
# VITE_AUTH_REQUIRED=true

# The base URL of the NyxID authentication server.
# Example: http://127.0.0.1:8081
VITE_NYXID_BASE_URL=http://127.0.0.1:8081

# The client ID registered in NyxID for this application.
VITE_NYXID_CLIENT_ID=fkst-hosted-console

# The redirect URI registered in NyxID for this application's oauth callback.
# If unset, defaults to `${origin}/auth/callback` at runtime.
# VITE_NYXID_REDIRECT_URI=http://127.0.0.1:5173/auth/callback
