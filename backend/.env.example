# ==============================================================================
# FKST Hosted Backend - Environment Variables Template (.env.example)
# ==============================================================================
#
# Copy this file to '.env' in the backend directory to configure the API server.
#
# This file documents two configuration profiles:
# (A) DEFAULT/production: Full NyxID authentication enabled, fail-closed posture, GitHub App active.
# (B) DEV/observer: Authentication disabled (all routes open), zero secrets, no GitHub App.
#
# ------------------------------------------------------------------------------
# PROFILE (A) - DEFAULT/PRODUCTION PROFILE (Full Auth, GitHub App Integration)
# ------------------------------------------------------------------------------
# FKST_AUTH_ENABLED=true
# FKST_AUTH_NYXID_BASE_URL=https://nyx.chrono-ai.fun
# FKST_AUTH_ISSUER=nyxid
# FKST_AUTH_AUDIENCE=https://nyx.chrono-ai.fun
# NYXID_CLIENT_ID=sa_REPLACE_ME_prod
# NYXID_CLIENT_SECRET=sa_sec_REPLACE_ME_prod
# FKST_GITHUB_APP_ID=123456
# FKST_GITHUB_APP_PRIVATE_KEY_PEM="-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----"
# FKST_GITHUB_APP_SLUG=fkst-hosted
# FKST_GITHUB_WRITE=REAL # Engine/deployment-level — not consumed by fkst-control-plane
#
# ------------------------------------------------------------------------------
# PROFILE (B) - DEV/OBSERVER PROFILE (Local Dev, Open Routes, Zero Secrets)
# ------------------------------------------------------------------------------
# FKST_AUTH_ENABLED=false
# # GitHub App configuration is omitted (disabled posture).
# # NyxID client credentials are omitted (owner-only policy).
# FKST_GITHUB_WRITE=DRY-RUN # Engine/deployment-level — not consumed by fkst-control-plane

# ==============================================================================
# DETAILED ENV VAR CONFIGURATION & DEFAULTS
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Datastore Configuration
# ------------------------------------------------------------------------------
# The controller is datastore-free (#143): there is NO database. Sessions live
# in an in-memory store, goals are GitHub-Issue + in-memory backed, the journal's
# sole machine-truth is the committed GitHub file, and secrets are held in memory
# only. No MONGODB_* (or any other datastore) variable is read or required.


# ------------------------------------------------------------------------------
# 2. HTTP Server Configuration
# ------------------------------------------------------------------------------

# Optional. TCP port the HTTP server binds to.
# Default: 8080
FKST_HOSTED_PORT=8080

# Optional. Bind address.
# Default: 0.0.0.0
FKST_HOSTED_BIND_ADDR=0.0.0.0

# Optional. tracing-subscriber EnvFilter directive (e.g. debug, info, fkst_control_plane=debug).
# Default: info
FKST_HOSTED_LOG_LEVEL=info

# Optional. Per-request timeout in seconds for tower-http TimeoutLayer.
# Must be >= 1.
# Default: 30
FKST_HOSTED_REQUEST_TIMEOUT_SECS=30


# ------------------------------------------------------------------------------
# 3. NyxID JWT Authentication (FKST_AUTH_*)
# ------------------------------------------------------------------------------

# Optional. Master toggle for NyxID JWT verification.
# Default: true (fail-closed, must explicitly set to false to disable)
FKST_AUTH_ENABLED=true

# Required when FKST_AUTH_ENABLED is true. Base URL of the NyxID service.
# Trailing slashes are automatically trimmed.
FKST_AUTH_NYXID_BASE_URL=https://nyx.chrono-ai.fun

# Optional. Expected JWT issuer ('iss') claim. Must match the issuer in the NyxID token.
# Default: nyxid
FKST_AUTH_ISSUER=nyxid

# Optional. Expected JWT audience ('aud') claim. Defaults to the FKST_AUTH_NYXID_BASE_URL value.
FKST_AUTH_AUDIENCE=https://nyx.chrono-ai.fun

# Optional. JWKS public key cache TTL in seconds. Must be >= 1.
# Default: 300
FKST_AUTH_JWKS_CACHE_TTL_SECS=300


# ------------------------------------------------------------------------------
# 4. NyxID Service Account (Org Membership & GitHub Connection Proxy)
# ------------------------------------------------------------------------------
# Both-or-neither: if one is set, the other must be set. If omitted, platform
# org features degrade gracefully (enforcing an owner-only authorization policy).

# Optional. NyxID service-account client ID for fetching org roles/policies.
# NYXID_CLIENT_ID=sa_REPLACE_ME

# Optional. NyxID service-account client secret (SECRET).
# NYXID_CLIENT_SECRET=sa_sec_REPLACE_ME

# Optional. TTL in seconds for NyxID org roles and user-orgs membership caches.
# Default: 30
FKST_NYXID_ORG_CACHE_TTL_SECS=30


# ------------------------------------------------------------------------------
# 5. GitHub App Integration (Session Work & Git Posture)
# ------------------------------------------------------------------------------
# Configures session-scoped git operations (cloning, writing files, pushing).
# Module is disabled if FKST_GITHUB_APP_ID is unset.

# Optional. The GitHub App's numeric ID (unset = module disabled).
# FKST_GITHUB_APP_ID=

# Required if FKST_GITHUB_APP_ID is set. Inline PEM private key.
# Use literal '\n' escapes for newlines. Mutually exclusive with _PATH.
# FKST_GITHUB_APP_PRIVATE_KEY_PEM="-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----"

# Required if FKST_GITHUB_APP_ID is set. Path to a local private key PEM file.
# Mutually exclusive with _PEM.
# FKST_GITHUB_APP_PRIVATE_KEY_PATH=/etc/fkst-github-app/key.pem

# Optional. URL-friendly slug of the GitHub App (e.g. "fkst-hosted").
# Used to construct actionable installation-hint URLs in 422 error messages.
# FKST_GITHUB_APP_SLUG=

# Optional. Global write posture (engine/deployment-level — not consumed by fkst-control-plane; governs the substrate dev-loop write posture).
# Default: DRY-RUN (no writes/merges carried out).
# Set to 'REAL' (or '1') in production to enable autonomous writes/merges.
FKST_GITHUB_WRITE=DRY-RUN


# ------------------------------------------------------------------------------
# 6. LLM Gateway Configuration
# ------------------------------------------------------------------------------
# Optional. Used for POST /api/v1/packages/generate endpoint.
# If URL is set, both NYXID_CLIENT_ID/SECRET and FKST_HOSTED_LLM_MODEL are required.

# Optional. NyxID LLM gateway URL. (e.g., https://nyx.chrono-ai.fun/api/v1/llm/gateway/v1)
# FKST_HOSTED_LLM_GATEWAY_URL=

# Required when LLM gateway is set. Model identifier (e.g. claude-3-5-sonnet).
# FKST_HOSTED_LLM_MODEL=

# Optional. LLM completion timeout in seconds.
# Default: 20
FKST_HOSTED_LLM_TIMEOUT_SECS=20

# Optional. Max output bytes from LLM completion before rejection.
# Default: 1048576 (1 MiB)
FKST_HOSTED_LLM_MAX_OUTPUT_BYTES=1048576


# ------------------------------------------------------------------------------
# 7. Journaling Configuration (Status Commits)
# ------------------------------------------------------------------------------

# Optional. Master token for fallback journaling repository access.
# If absent, GitHub journaling is disabled (no durable floor) with a warning.
# GITHUB_TOKEN=ghp_REPLACE_ME

# Optional. Switch to enable/disable GitHub journaling (the sole machine-truth).
# Default: true
FKST_JOURNAL_GITHUB_ENABLED=true

# Optional. Owner/name of the dedicated journal repo.
# If absent, GitHub journaling is disabled (no durable floor, warning).
# FKST_JOURNAL_GITHUB_REPO=

# Optional. Git branch to push journals to.
# Default: main
FKST_JOURNAL_GITHUB_BRANCH=main

# Optional. Flush debounce time in milliseconds for buffering completions.
# Default: 2000
FKST_JOURNAL_FLUSH_INTERVAL_MS=2000

# Optional. Force flush once buffer reaches this size.
# Default: 50
FKST_JOURNAL_FLUSH_MAX_BATCH=50

# Optional. Mirror completions as issue comments on GitHub (disabled by default).
# Default: false
FKST_JOURNAL_ISSUE_COMMENTS=false

# Optional. Max retries for handling optimistic concurrency conflicts.
# Default: 5
FKST_JOURNAL_CAS_MAX_RETRIES=5


# ------------------------------------------------------------------------------
# 8. Event Identity Pointers
# ------------------------------------------------------------------------------

# Optional. Comma-separated JSON pointers used to define event uniqueness.
# Default: /department,/source,/name,/corr
FKST_RAISED_IDENTITY_POINTERS=/department,/source,/name,/corr

# Optional. Max stdout line length parsed before truncation.
# Default: 1048576
FKST_RAISED_MAX_LINE_BYTES=1048576
